<!DOCTYPE html>
<html lang="mn">
<head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>My website</title>
<style>
body{margin:0;font-family:sans-serif;background:#dff0d8;text-align:center}
h1,p{margin:.5rem 0}
table{margin:8px auto;border-collapse:collapse}td{border:1px solid #000;padding:6px}
tr:nth-child(2) td:nth-child(2){background:brown;color:#fff}
input,textarea,select{margin:6px;padding:6px;border:1px solid #666}
.btn{background:blue;color:#fff;padding:6px 10px;border:none;cursor:pointer;transition:background .2s}
.btn:hover{background:red}
img{display:block;margin:8px auto;border:3px solid #666;animation:pop .3s both}
@keyframes pop{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
@media(max-width:600px){body{background:yellow}}
</style>
</head>
<body>
<h1>My website</h1>
<p>Paragraph 1</p>
<p>Paragraph 2</p>
<table>
<tr><td>r1c1</td><td>r1c2</td></tr>
<tr><td>r2c1</td><td>r2c2</td></tr>
<tr><td>r3c1</td><td>r3c2</td></tr>
</table>
<form action="#" style="max-width:360px;margin:0 auto">
<input type="text" placeholder="Name"><br>
<textarea rows="2" placeholder="Text"></textarea><br>
<select><option>1</option></select><br>
<label><input type="radio" name="r" checked> A</label><label><input type="radio" name="r"> B</label><br>
<button class="btn" type="submit">Send</button>
</form>
<p><a href="https://example.com" target="_blank" rel="noopener">Other site</a></p>
<img src="https://via.placeholder.com/150" alt="Example image">
</body>
</html>